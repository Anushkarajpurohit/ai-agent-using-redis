# --- Database ---
DATABASE_URL=postgres://postgres:root@localhost:5432/claude-maya

# --- Redis (optional, falls back to in-memory Map cache if unset/unreachable) ---
REDIS_URL=redis://localhost:6379

# --- Ollama (LLM used ONLY for phrasing, never for decisions) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b 
LLM_PHRASING_TIMEOUT_MS=17000
# --- Voice I/O ---
# No STT/TTS server config here on purpose. Voice runs entirely in the
# browser via the Web Speech API (SpeechRecognition + speechSynthesis) —
# zero extra network hops, zero servers to run. See README "Voice I/O".

# --- Cache TTLs (seconds) ---
CACHE_TTL_DOCTORS=600
CACHE_TTL_SLOTS=300
CACHE_TTL_SESSION=15000
